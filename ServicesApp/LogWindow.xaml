<Window
    x:Class="ServicesApp.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ServicesApp"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="32" Grid.Row="0" Background="Transparent">
            <TextBlock x:Name="TitleText" Text="日志" VerticalAlignment="Center" Margin="16,0,0,0" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.8"/>
        </Grid>

        <Grid Grid.Row="1" Padding="16">
            <TextBox x:Name="LogTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     BorderThickness="0"
                     Background="{ThemeResource LayerFillColorDefaultBrush}"
                     CornerRadius="8"
                     Padding="12"/>
        </Grid>

        <Grid Grid.Row="2" Padding="16,0,16,16">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="RefreshButton" Content="刷新" Click="OnRefreshClick"/>
                <Button x:Name="OpenFolderButton" Content="打开日志文件" Click="OnOpenFolderClick"/>
                <Button Content="关闭" Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>